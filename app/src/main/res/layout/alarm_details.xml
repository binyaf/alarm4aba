<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/alarmDetailsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/very_light_grey"
    android:orientation="vertical"
    android:textAlignment="center">

    <!-- App bar -->
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_include" />

    <!-- Upper Part (Top Buttons) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addAdditionAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="@string/add"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/colorPrimary"
            app:icon="@drawable/add_icon"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/editAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/light_grey"
            app:icon="@drawable/edit_icon"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:visibility="gone"
            android:contentDescription="@string/edit" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/light_red"
            app:icon="@drawable/delete_icon"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:visibility="gone"
            android:contentDescription="@string/delete" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shareAlarmButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/light_green"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:visibility="gone"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:contentDescription="@string/share" />
    </LinearLayout>

    <!-- divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/very_light_grey" />

    <!-- list of alarms (dynamically) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/alarmsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/remind_me_about"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reminders_advanced_settings"
                    android:alpha="0.7"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- prayer reminders -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shacharit_vatikin"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="2dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/shacharit_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:contentDescription="@string/shacharit_switch_desc" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mincha"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="2dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/mincha_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:contentDescription="@string/mincha_switch_desc" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/maariv"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="2dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/maariv_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:contentDescription="@string/maariv_switch_desc" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/candle_lighting"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="2dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/candle_lighting_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        android:contentDescription="@string/candle_switch_desc" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="@color/very_light_grey" />

            <!-- bottom buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/timeIconImageView"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/time_icon"
                    android:contentDescription="@string/time_icon_desc" />

                <TextView
                    android:id="@+id/labelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/todays_zmanim"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:contentDescription="@string/app_icon_desc" />

</LinearLayout>