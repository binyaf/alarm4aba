<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/alarmDetailsMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/very_light_grey"
    android:orientation="vertical"
    android:textAlignment="center">

    <!-- App bar -->
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_include" />

    <!-- Upper Part (Top Buttons) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addAdditionAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="@string/add"
            android:textAllCaps="false"
            android:background="@drawable/rounded_corner"
            app:backgroundTint="@color/colorPrimary"
            app:icon="@drawable/add_icon"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/editAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rounded_corner"
            app:backgroundTint="@color/light_grey"
            app:icon="@drawable/edit_icon"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:visibility="gone"
            android:contentDescription="@string/edit" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteAlarmBtn"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rounded_corner"
            app:backgroundTint="@color/light_red"
            app:icon="@drawable/delete_icon"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:visibility="gone"
            android:contentDescription="@string/delete" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/shareAlarmButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/rounded_corner"
            app:backgroundTint="@color/light_green"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:enabled="false"
            android:visibility="gone"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:contentDescription="@string/share" />
    </LinearLayout>

    <!-- divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray" />

    <!-- list of alarms (dynamically) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/alarmsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp" />

    <!-- divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray" />

    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="1dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:text="@string/remind_me_about"
            android:padding="5dp"
            android:textSize="18dp"/>

        <TextView
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            android:text="@string/reminders_advanced_settings"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:textSize="12dp"/>
    </LinearLayout>

    <!-- prayer reminders -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="2dp"
        android:paddingRight="2dp"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shacharit_vatikin"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/shacharit_reminder_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:contentDescription="@string/shacharit_switch_desc" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mincha"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/mincha_reminder_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:contentDescription="@string/mincha_switch_desc" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/maariv"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/maariv_reminder_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:contentDescription="@string/maariv_switch_desc" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_margin="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/candle_lighting"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/candle_lighting_reminder_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:contentDescription="@string/candle_switch_desc" />
        </LinearLayout>
    </LinearLayout>

    <!-- divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray" />

    <!-- bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="fill_vertical"
        android:padding="10dp"
        android:orientation="vertical">

    <ImageView
        android:id="@+id/timeIconImageView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:src="@drawable/time_icon"
        android:contentDescription="@string/time_icon_desc" />

    <TextView
        android:id="@+id/labelTextView"
        android:labelFor="@+id/timeIconImageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/todays_zmanim"
        android:layout_marginBottom="20dp"
        android:textColor="#3434AD" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:gravity="bottom|center"
        android:contentDescription="@string/app_icon_desc" />
    </LinearLayout>

</LinearLayout>